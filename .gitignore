# --- Logs ---
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Dependencies / build outputs (web) ---
node_modules
dist
dist-ssr
coverage
*.local
.parcel-cache/

# --- Editor / OS ---
.DS_Store
.vscode/*
!.vscode/extensions.json
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- TS / lint caches ---
*.tsbuildinfo
.eslintcache

# --- Cypress / Vitest ---
/cypress/videos/
/cypress/screenshots/
__screenshots__/

# --- Vite ---
*.timestamp-*-*.mjs

# --- Environment secrets (NEVER commit) ---
.env
.env.*
!.env.example

# --- Capacitor (generated by `cap sync`) ---
# Web bundle copied into native projects is regenerated from `dist/`.
android/app/src/main/assets/public/
ios/App/App/public/

# --- Android (Gradle / Android Studio) ---
android/.gradle/
android/build/
android/app/build/
android/captures/
android/.idea/
android/local.properties
android/app/release/
android/app/debug/
*.apk
*.aab
*.keystore
*.jks

# --- iOS (Xcode / CocoaPods) ---
# NOTE: Podfile.lock IS committed (locks CocoaPods versions across machines).
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/DerivedData/
ios/build/
*.mobileprovision
*.p12
